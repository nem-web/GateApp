{
  "buildCommand": "npm run prisma:generate && npm run build",
  "env": {
    "NEXTAUTH_SECRET": "@nextauth_secret",
    "NEXTAUTH_URL": "@nextauth_url",
    "DATABASE_URL": "@database_url"
  },
  "functions": {
    "src/middleware.ts": {
      "maxDuration": 10
    },
    "src/app/api/**": {
      "maxDuration": 10
    }
  }
}
