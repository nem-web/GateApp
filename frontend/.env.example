# Postgres (Neon / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gateprep?sslmode=require"

# Auth — https://next-auth.js.org/configuration/options#secret
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Free AI — set at least one (Groq recommended)
# https://console.groq.com/keys
GROQ_API_KEY=""
# Optional override
# GROQ_MODEL="llama-3.3-70b-versatile"

# Fallback — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Admin login. Store only a bcrypt hash, never the plaintext password.
# Escape bcrypt $ characters as \$ in .env files used by Next.js.
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""
