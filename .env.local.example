# Local Development Environment
# Copy this to .env.local for local testing

# Local database setup (for local development)
DATABASE_URL="******localhost:5432/gateprep"

# NextAuth Configuration
# For local development, use http://localhost:3000
NEXTAUTH_SECRET="your-local-secret-for-testing-only"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (leave empty if not using)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: AI API Keys (leave empty if not using)
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
GEMINI_API_KEY=""

# ========================================
# VERCEL DEPLOYMENT ENVIRONMENT
# ========================================
# When deploying to Vercel, set these in Vercel Dashboard → Settings → Environment Variables
#
# DATABASE_URL=your-production-db-connection-string
# NEXTAUTH_SECRET=<generated-with-openssl-rand-base64-32>
# NEXTAUTH_URL=https://your-app-name.vercel.app
# 
# Note: Do NOT commit .env or .env.local to git
# .env files are in .gitignore for security
